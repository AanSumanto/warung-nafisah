# Warung Nafisah ERP — Root environment template
# Workspace-specific config: backend/.env, frontend/.env.local

NODE_ENV=development

# MongoDB (deployment/docker-compose.yml)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=warung_nafisah

# Redis — use REDIS_URL in backend/.env (see backend/.env.example)
# Local OSS: redis://localhost:6379

# Backend API (native — port 5000 per ADR-001)
# PORT=5000

# Frontend (native — port 3000)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
