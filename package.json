{
  "name": "warung-nafisah",
  "version": "0.7.0",
  "private": true,
  "description": "Warung Nafisah ERP — Internal Restaurant Management System",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "scaffold": "node scripts/scaffold-folders.mjs",
    "verify:structure": "node scripts/verify-structure.mjs",
    "verify:repo": "npm run verify:structure && npm run format:check && npm run lint",
    "lint": "eslint scripts --ext .js,.mjs,.cjs",
    "format": "prettier --write \"**/*.{js,mjs,cjs,json,md,yml,yaml}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{js,mjs,cjs,json,md,yml,yaml}\" --ignore-path .prettierignore",
    "build": "node scripts/build.mjs",
    "dev": "node scripts/dev.mjs",
    "test": "npm run test --workspace=@warung-nafisah/backend && npm run test --workspace=@warung-nafisah/frontend",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
