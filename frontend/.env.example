# Warung Nafisah ERP — Frontend
# Copy to .env.local

# Local dev: backend on port 5000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Production: backend URL (Nevacloud VPS)
# NEXT_PUBLIC_API_BASE_URL=http://202.155.90.209:5000
# Recommended: use HTTPS domain when available
# NEXT_PUBLIC_API_BASE_URL=https://api.warungnafisah.com

# Vercel same-origin (only if API is proxied on same domain): leave empty
# NEXT_PUBLIC_API_BASE_URL=

NEXT_PUBLIC_APP_NAME=Warung Nafisah ERP
