# Warung Nafisah ERP — Frontend
# Copy to .env.local

# --- Local development (direct to backend) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# --- Production on Vercel + HTTP backend (Nevacloud) ---
# Browser calls same-origin HTTPS; Vercel proxies to backend (no Mixed Content).
# Set on Vercel Dashboard (NOT NEXT_PUBLIC):
#   API_PROXY_TARGET=http://202.155.90.209:5000
#   NEXT_PUBLIC_API_BASE_URL=          (leave empty)
#
# Recommended long-term: HTTPS domain on backend, then set:
#   NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com

NEXT_PUBLIC_APP_NAME=Warung Nafisah ERP
