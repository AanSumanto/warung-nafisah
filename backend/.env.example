# Warung Nafisah ERP — Backend
# Copy to .env

NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# MongoDB — Existing Host Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=warung_nafisah

# Redis — SINGLE connection string (required)
# Local OSS:
#   REDIS_URL=redis://localhost:6379
# Redis Cloud:
#   REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:6379
# Upstash:
#   REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6379
REDIS_URL=redis://localhost:6379

LOG_LEVEL=info

# Comma-separated browser origins (scheme + host + optional port, no trailing path)
# Development:
CORS_ORIGINS=http://localhost:3000

# Production (Nevacloud) — HTTPS only, no localhost:
# CORS_ORIGINS=https://warung-nafisah.vercel.app
# Multiple origins:
# CORS_ORIGINS=https://warung-nafisah.vercel.app,https://preview-branch.vercel.app

# Required in production — use a strong random string (min 32 chars)
# JWT_SECRET=change-me-in-production

# Production (Nevacloud + PM2)
# NODE_ENV=production
# LOG_LEVEL=warn
