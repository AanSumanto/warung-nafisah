{
  "name": "@warung-nafisah/backend",
  "version": "0.11.2",
  "private": true,
  "description": "Warung Nafisah ERP — Backend API",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "pm2:start": "npm run build && pm2 start ecosystem.config.cjs --env production",
    "pm2:startOrReload": "pm2 startOrReload ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop warung-nafisah-api",
    "pm2:restart": "pm2 restart warung-nafisah-api --env production",
    "pm2:reload": "pm2 reload warung-nafisah-api --env production",
    "pm2:delete": "pm2 delete warung-nafisah-api",
    "pm2:logs": "pm2 logs warung-nafisah-api",
    "pm2:status": "pm2 status warung-nafisah-api",
    "deploy:pm2": "npm run build && npm run pm2:startOrReload",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.34.8",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.3",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "mongodb-memory-server": "^10.1.4",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
